-- ============================================
-- FIX #1: ANTI AFK — proactive loop + Idled fallback
-- Roblox kicks at 20 min idle → we press W every 14 min
-- ============================================
local function setAntiAfk(on)
    antiAfkOn = on
    if antiAfkConn then
        antiAfkConn:Disconnect()
        antiAfkConn = nil
    end
    if antiAfkThread then
        task.cancel(antiAfkThread)
        antiAfkThread = nil
    end
    if on then
        -- Proactive loop: reset idle timer every 14 minutes
        antiAfkThread = task.spawn(function()
            while antiAfkOn do
                task.wait(14 * 60) -- 14 minutes
                if not antiAfkOn then break end
                -- Method 1: VirtualInputManager
                pcall(function()
                    local vp = game:GetService("VirtualInputManager")
                    vp:SendKeyEvent(true,  Enum.KeyCode.W, false, game)
                    task.wait(0.15)
                    vp:SendKeyEvent(false, Enum.KeyCode.W, false, game)
                end)
                -- Method 2: Humanoid move (backup)
                pcall(function()
                    local char = lp.Character
                    local hum  = char and char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        hum:Move(Vector3.new(0, 0, -1))
                        task.wait(0.15)
                        hum:Move(Vector3.new(0, 0, 0))
                    end
                end)
            end
        end)
        -- Backup: also fire when Idled event triggers
        antiAfkConn = lp.Idled:Connect(function()
            pcall(function()
                local vp = game:GetService("VirtualInputManager")
                vp:SendKeyEvent(true,  Enum.KeyCode.W, false, game)
                task.wait(0.1)
                vp:SendKeyEvent(false, Enum.KeyCode.W, false, game)
            end)
        end)
    end
end

